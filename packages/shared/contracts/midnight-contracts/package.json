{
  "name": "@kart-legends/midnight-contracts",
  "version": "0.3.0",
  "type": "module",
  "exports": {
    "./[contract-name]": "./contract-[contract-name]/src/index.original.ts"
  },
  "scripts": {
    "midnight-node:start": "CFG_PRESET=dev bun ./node_modules/.bin/npm-midnight-node --dev --rpc-port 9944 --state-pruning archive --blocks-pruning archive --public-addr /ip4/127.0.0.1 --unsafe-rpc-external",
    "midnight-node:wait": "wait-on tcp:9944",
    "midnight-indexer:start": "CONFIG_FILE=`pwd`/indexer-standalone/config.yaml LEDGER_NETWORK_ID=\"Undeployed\" SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" APP__INFRA__SECRET=$(openssl rand -hex 32 | tr 'a-f' 'A-F') FEATURES_WALLET_ENABLED=\"true\" APP__INFRA__NODE__URL=\"ws://localhost:9944\" bun ./node_modules/.bin/npm-midnight-indexer --binary --clean",
    "midnight-indexer:wait": "wait-on tcp:8088",
    "midnight-proof-server:start": "LEDGER_NETWORK_ID=\"Undeployed\" RUST_BACKTRACE=full SUBSTRATE_NODE_WS_URL=\"ws://localhost:9944\" bun ./node_modules/.bin/npm-midnight-proof-server",
    "midnight-proof-server:wait": "wait-on tcp:6300",
    "midnight-contract:clean": "rm -rf midnight-level-db && rm -rf contract.json",
    "midnight-contract:deploy": "bun run midnight-contract:clean && bun run deploy.ts",
    "compact": "bun run --filter @kart-legends/midnight-contract-midnight-data compact"
  },
  "dependencies": {
    "@effectstream/midnight-contracts": "0.100.26",
    "@effectstream/npm-midnight-indexer": "0.100.26",
    "@effectstream/npm-midnight-node": "0.100.26",
    "@effectstream/npm-midnight-proof-server": "0.100.26",
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/zswap": "4.0.0"
  }
}
