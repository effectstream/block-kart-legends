{
  "name": "@kart-legends/evm-contracts",
  "version": "0.3.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./mod.ts",
    "./build": "./build/mod.ts",
    "./contractAddressesEvmMain": "./build/contractAddressesEvmMain.ts"
  },
  "scripts": {
    "swap:remappings:forge": "bun ./node_modules/@effectstream/evm-hardhat/src/remappings/remappings-forge.ts --depth=0",
    "swap:remappings:hardhat": "bun ./node_modules/@effectstream/evm-hardhat/src/remappings/remappings-hardhat.ts --depth=0",
    "check": "echo 'check'",
    "build:mod": "(bun run deploy:standalone || true) && bun run build && bun -e 'await import(\"@effectstream/evm-hardhat/builder\")'",
    "build:clean": "rm -rf build || true",
    "build:forge": "bun run swap:remappings:forge && forge build",
    "build:hardhat": "bun run swap:remappings:hardhat && bun ./node_modules/.bin/hardhat compile",
    "build": "bun run build:clean && bun run build:forge && bun run build:hardhat",
    "contract:compile": "bun run build:mod",
    "deploy:clean": "rm -rf ignition/deployments/chain-31337 || true",
    "deploy:standalone": "(((bun run chain:start) &) && (bun run chain:wait) && (bun run deploy) && bun run chain:stop) || true",
    "deploy:testnet": "bun run build && bun run deploy.testnet.ts",
    "deploy:mainnet": "bun run build && bun run deploy.mainnet.ts",
    "deploy": "bun run deploy.ts",
    "chain:start": "bun ./node_modules/.bin/hardhat node",
    "chain:stop": "kill -9 $(lsof -ti tcp:8545) || true",
    "chain:wait": "bun ./node_modules/.bin/hardhat node wait"
  },
  "dependencies": {
    "@effectstream/evm-contracts": "0.100.23",
    "@effectstream/evm-hardhat": "0.100.23",
    "@effectstream/log": "0.100.23",
    "@nomicfoundation/hardhat-errors": "3.0.1",
    "@nomicfoundation/hardhat-ignition": "3.0.2",
    "@nomicfoundation/hardhat-ignition-viem": "3.0.2",
    "@nomicfoundation/hardhat-utils": "3.0.0",
    "@nomicfoundation/hardhat-viem": "3.0.0",
    "@nomicfoundation/ignition-core": "3.0.2",
    "@openzeppelin/contracts": "5.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.1.0",
    "@wagmi/cli": "2.3.1",
    "ws": "8.18.1"
  },
  "devDependencies": {
    "@opentelemetry/sdk-node": "0.56.0",
    "hardhat": "3.9.0",
    "jsonc-parser": "3.3.1",
    "wait-on": "8.0.3"
  }
}
